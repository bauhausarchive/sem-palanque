# PostgreSQL / Supabase
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/politico_transparente
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-anon-key

# App settings
SECRET_KEY=change-me-in-production
ENVIRONMENT=development
ALLOWED_ORIGINS=http://localhost:3000,https://your-github-pages-url.github.io

# Optional: Cache
REDIS_URL=redis://localhost:6379/0

# NLP model (defaults used if not set)
SENTENCE_TRANSFORMER_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
BERT_PORTUGUESE_MODEL=neuralmind/bert-base-portuguese-cased
